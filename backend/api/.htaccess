RewriteEngine On

# Handle CORS preflight
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route products
RewriteRule ^api/products/?$ api/products.php [L]
RewriteRule ^api/products/([a-zA-Z0-9-]+)/?$ api/products.php [L]

# Route orders
RewriteRule ^api/orders/?$ api/orders.php [L]
RewriteRule ^api/orders/([a-zA-Z0-9-]+)/?$ api/orders.php [L]

# Route auth
RewriteRule ^api/auth/(.+)/?$ api/auth.php [L]

# Route upload
RewriteRule ^api/upload/?$ api/upload.php [L]

# Route blacklist
RewriteRule ^api/blacklist/?$ api/blacklist.php [L]
RewriteRule ^api/blacklist/([a-zA-Z0-9-]+)/?$ api/blacklist.php [L]
